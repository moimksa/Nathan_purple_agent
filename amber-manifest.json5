{
  // Amber manifest for car_bench_agent (AgentX / AgentBeats)
  manifest_version: "0.1.0",

  config_schema: {
    type: "object",
    properties: {},
    additionalProperties: false,
  },

  program: {
    image: "ghcr.io/moimksa/nathan_purple_agent-purple-agent:0.1.0",
    entrypoint: "uv run src/purple_car_bench_agent/server.py --host 0.0.0.0 --port 8080",
    network: {
      endpoints: [{ name: "a2a_endpoint", port: 8080 }],
    },
  },

  provides: {
    a2a: { kind: "a2a", endpoint: "a2a_endpoint" },
  },

  exports: {
    a2a: "a2a",
  },
}
